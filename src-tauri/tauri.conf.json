{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "duanwu-lab",
  "identifier": "com.johnie.duanwu-lab",
  "build": {
    "beforeDevCommand": "npx @tailwindcss/cli -i assets/tailwind.css -o assets/styles.css && npx @tailwindcss/cli -i assets/tailwind.css -o assets/styles.css --watch & dx serve --port 1420 --interactive false",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "duanwu-lab",
        "width": 1280,
        "height": 720
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
